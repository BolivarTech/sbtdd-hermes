# SBTDD Backend Configuration
# Precedence (per key): env > this file (repo) > ~/.hermes/sbtdd.toml > built-in
#
# This configures an OpenAI-compatible backend (Ollama, OpenRouter, etc.)
# for automated SBTDD phases that the main Hermes model cannot handle.
#
# SECURITY: api_key is read from env var SBTDD_BACKEND_API_KEY only.
# Do NOT write real keys here — this file may be committed.

# OpenAI-compatible base URL.
base_url = "http://localhost:11434/v1"

[phases]
# Per-phase model selection. The backend receives the phase name
# and uses the corresponding model for generation.
#
# Recommendation:
#   - thinking models (deepseek-v4-pro, qwen-thinking) for brainstorming/planning
#   - coding models (kimi-k2.7-code, qwen-coder, claude-sonnet) for red/green/refactor

brainstorm = "deepseek-v4-pro:cloud"
planning   = "qwen3.5:397b-cloud"
red        = "kimi-k2.7-code:cloud"
green      = "kimi-k2.7-code:cloud"
refactor   = "kimi-k2.7-code:cloud"
